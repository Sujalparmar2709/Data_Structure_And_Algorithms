{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Run Current C++ File",
      "type": "shell",
      "command": "g++ \"${file}\" -o \"${fileDirname}\\${fileBasenameNoExtension}.exe\"; if ($?) { & \"${fileDirname}\\${fileBasenameNoExtension}.exe\" }",
      "options": {
        "shell": {
          "executable": "powershell",
          "args": [
            "-NoProfile",
            "-Command"
          ]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
